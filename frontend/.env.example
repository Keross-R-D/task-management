# ============================================================
# Task Management — Frontend Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env.local or .env.production with secrets.
# ============================================================

# ── Deployment Base Path (leave empty for local dev) ─────────
# Only set this for production builds (e.g. /apps/task-management/v1/)
VITE_BASE_PATH=

# ── Task Management Backend API ──────────────────────────────
VITE_API_BASE_URL=

# ── IKON Platform ─────────────────────────────────────────────
VITE_IKON_API_URL=
VITE_IKON_PLATFORM_UI_URL=
VITE_LOGIN_PAGE_URL=

# ── IKON User Management API ──────────────────────────────────
VITE_IKON_USER_API_URL=
