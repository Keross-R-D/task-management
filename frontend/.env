# ============================================================
# Task Management — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local to override values without
# committing secrets. .env.local is git-ignored.
# All variables exposed to the browser MUST be prefixed VITE_
# ============================================================

# ── Task Management Backend API ──────────────────────────────
VITE_API_BASE_URL=http://localhost:8071/api

# ── IKON Platform ─────────────────────────────────────────────
VITE_IKON_API_URL=https://ikoncloud-dev.keross.com/ikon-api
VITE_IKON_PLATFORM_UI_URL=http://localhost:3000
VITE_LOGIN_PAGE_URL=/login

# ── IKON User Management API ──────────────────────────────────
VITE_IKON_USER_API_URL=https://ikoncloud-dev.keross.com/ikon-api/platform/user/current
