# ============================================================
# Task Management — Backend Environment Variables (EXAMPLE)
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real credentials.
# ============================================================

# ── Server ───────────────────────────────────────────────────
SERVER_PORT=
SERVER_ADDRESS=

# ── PostgreSQL Database ───────────────────────────────────────
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# ── MongoDB ──────────────────────────────────────────────────
MONGO_HOST=
MONGO_PORT=
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_AUTH_DB=

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_SCHEMA_REGISTRY_URL=

# ── IKON Platform ────────────────────────────────────────────
IKON_PLATFORM_URL=
IKON_JWT_ISSUER_URI=
IKON_SOFTWARE_ID=

# ── BPMN / Process Engine ────────────────────────────────────
BPMN_PATH=
BPMN_PROJECT_JSON=

# ── Eureka (Service Discovery) ───────────────────────────────
EUREKA_DEFAULT_ZONE=
EUREKA_REGISTER=
EUREKA_FETCH=
